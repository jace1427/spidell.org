---
import type { CollectionEntry } from 'astro:content';
import { formatDate } from '../utils/date';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
---

<article
  class="flex flex-col rounded-lg border p-6 transition-shadow hover:shadow-md"
  style="border-color: var(--color-border); background: var(--color-surface);"
>
  <h3 class="text-xl">
    <a href={`/projects/${project.id}`} class="no-underline" style="color: var(--color-fg);">
      {project.data.title}
    </a>
  </h3>
  <p class="mt-2 flex-1 text-sm" style="color: var(--color-muted);">
    {project.data.description}
  </p>
  <p class="mt-4 text-xs" style="color: var(--color-muted);">
    {formatDate(project.data.pubDate)}
  </p>
  {
    project.data.tags && project.data.tags.length > 0 && (
      <ul class="mt-3 flex flex-wrap gap-2">
        {project.data.tags.map((tag) => (
          <li
            class="rounded-full px-2.5 py-0.5 text-xs"
            style="background: var(--color-bg); color: var(--color-muted);"
          >
            {tag}
          </li>
        ))}
      </ul>
    )
  }
</article>
