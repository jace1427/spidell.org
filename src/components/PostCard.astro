---
import type { CollectionEntry } from 'astro:content';
import { formatDate } from '../utils/date';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
---

<article class="border-b py-8 last:border-b-0" style="border-color: var(--color-border);">
  <h3 class="text-xl">
    <a href={`/blog/${post.id}`} class="no-underline" style="color: var(--color-fg);">
      {post.data.title}
    </a>
  </h3>
  <p class="mt-1 text-sm" style="color: var(--color-muted);">
    {formatDate(post.data.pubDate)}
  </p>
  <p class="mt-3" style="color: var(--color-muted);">
    {post.data.description}
  </p>
  <a href={`/blog/${post.id}`} class="mt-3 inline-block text-sm font-medium no-underline">
    Read more →
  </a>
</article>
