---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact"
  description="Get in touch with Justin Spidell."
>
  <article class="mx-auto max-w-3xl px-6 py-16 md:py-20">
    <h1 class="text-4xl md:text-5xl">Contact</h1>
    <p class="mt-6 text-lg" style="color: var(--color-muted);">
      The fastest way to reach me is email. I'm also on GitHub and LinkedIn.
    </p>

    <ul class="mt-10 space-y-6 text-lg">
      <li>
        <span class="block text-sm font-medium uppercase tracking-wide" style="color: var(--color-muted);">Email</span>
        <a href="mailto:justin@spidell.org" class="font-medium no-underline">justin@spidell.org</a>
      </li>
      <li>
        <span class="block text-sm font-medium uppercase tracking-wide" style="color: var(--color-muted);">GitHub</span>
        <a href="https://github.com/jace1427" class="font-medium no-underline" rel="noopener noreferrer">
          github.com/jace1427
        </a>
      </li>
      <li>
        <span class="block text-sm font-medium uppercase tracking-wide" style="color: var(--color-muted);">LinkedIn</span>
        <a href="https://www.linkedin.com/in/justinspidell1427/" class="font-medium no-underline" rel="noopener noreferrer">
          linkedin.com/in/justinspidell1427
        </a>
      </li>
    </ul>
  </article>
</BaseLayout>
