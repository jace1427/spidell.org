---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About"
  description="About Justin Spidell — SRE at TikTok USDS JV, former Microsoft SWE."
>
  <article class="mx-auto max-w-3xl px-6 py-16 md:py-20">
    <h1 class="text-4xl md:text-5xl">About</h1>
    <div class="prose mt-10" style="color: var(--color-muted);">
      <p>
        I'm Justin Spidell. I work as a Site Reliability Engineer at TikTok USDS JV.
        Before that I was a Software Engineer at Microsoft.
      </p>
      <h2 class="text-2xl" style="color: var(--color-fg);">Interests</h2>
      <ul>
        <li>AI and machine learning</li>
        <li>Embedded systems and hardware</li>
        <li>Site reliability and infrastructure</li>
        <li>Video games</li>
        <li>Unix — I run Arch, by the way</li>
      </ul>
      <h2 class="text-2xl" style="color: var(--color-fg);">Get in touch</h2>
      <p>
        Find me on <a href="https://github.com/jace1427" rel="noopener noreferrer">GitHub</a>
        or <a href="https://www.linkedin.com/in/justinspidell1427/" rel="noopener noreferrer">LinkedIn</a>,
        or reach out via the <a href="/contact">contact page</a>.
      </p>
    </div>
  </article>
</BaseLayout>
