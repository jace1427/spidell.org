---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About"
  description="About Justin Spidell — SRE at TikTok USDS JV, former Microsoft SWE."
>
  <article class="mx-auto max-w-3xl px-6 py-16 md:py-20">
    <h1 class="text-4xl md:text-5xl">About</h1>
    <div class="prose mt-10" style="color: var(--color-muted);">
      <p>
        I'm Justin Spidell. I work as a Site Reliability Engineer at TikTok USDS JV.
        Before that I was a Software Engineer at Microsoft.
      </p>
      <h2 class="text-2xl" style="color: var(--color-fg);">Interests</h2>
      <ul>
        <li>AI and machine learning</li>
        <li>Embedded systems and hardware</li>
        <li>Site reliability and infrastructure</li>
        <li>Video games</li>
        <li>Unix — I run Arch, by the way</li>
      </ul>
    </div>

    <h2 class="mt-12 text-2xl" style="color: var(--color-fg);">Get in touch</h2>
    <p class="mt-3 text-lg" style="color: var(--color-muted);">
      The fastest way to reach me is email. I'm also on GitHub and LinkedIn.
    </p>
    <ul class="mt-8 space-y-6 text-lg">
      <li>
        <span class="block text-sm font-medium uppercase tracking-wide" style="color: var(--color-muted);">Email</span>
        <a href="mailto:justin@spidell.org" class="font-medium no-underline">justin@spidell.org</a>
      </li>
      <li>
        <span class="block text-sm font-medium uppercase tracking-wide" style="color: var(--color-muted);">GitHub</span>
        <a href="https://github.com/jace1427" class="font-medium no-underline" rel="noopener noreferrer">
          github.com/jace1427
        </a>
      </li>
      <li>
        <span class="block text-sm font-medium uppercase tracking-wide" style="color: var(--color-muted);">LinkedIn</span>
        <a href="https://www.linkedin.com/in/justinspidell1427/" class="font-medium no-underline" rel="noopener noreferrer">
          linkedin.com/in/justinspidell1427
        </a>
      </li>
    </ul>
  </article>
</BaseLayout>
